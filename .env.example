APP_NAME=Zomato AI Recommender
APP_ENV=dev
APP_PORT=8000

# Data source
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
HF_DATASET_SPLIT=train

# Storage
SQLITE_PATH=data/restaurants.db

# Ingestion quality thresholds
CRITICAL_NULL_THRESHOLD=0.35
MAX_ALLOWED_DUPLICATE_RATIO=0.4

# Groq LLM (Phase 4)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
